---
import "../styles/global.css";
import { Font } from "astro:assets";

const base = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: import.meta.env.BASE_URL + "/";
const site = import.meta.env.SITE;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>Snake Oil & Gas</title>
		<meta
			name="description"
			content="What else is your ad agency selling? Some of the agencies working in healthcare also work for fossil fuel companies — whose pollution does wonders for cancer, asthma and everything in between."
		/>

		<meta property="og:title" content="Snake Oil & Gas" />
		<meta
			property="og:description"
			content="What else is your ad agency selling? Some of the agencies working in healthcare also work for fossil fuel companies — whose pollution does wonders for cancer, asthma and everything in between."
		/>
		<meta property="og:image" content={`${site}${base}snakeoil.gif`} />
		<meta property="og:type" content="website" />

		<link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
		<link rel="icon" href={`${base}favicon.ico`} />

		<Font cssVariable="--font-verve" preload />
		<Font cssVariable="--font-libre-baskerville" preload />

		<script
			defer
			src="https://cloud.umami.is/script.js"
			data-website-id="d0e3b86b-b601-4b5f-8dcd-c6d5d7d47558"></script>
	</head>
	<body class="bg-paper text-ink font-body min-h-screen">
		<slot />
	</body>
</html>

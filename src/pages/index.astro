---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import snakeoilImg from "../assets/snakeoil.png";
import snakeImg from "../assets/snake.png";

const base = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: import.meta.env.BASE_URL + "/";
---

<Layout>
	<main
		class="min-h-screen flex flex-col items-center justify-center px-4 py-8 sm:py-12 md:py-16 relative"
	>
		<!-- Paper texture overlay -->
		<div
			class="absolute inset-0 pointer-events-none z-0 opacity-30 mix-blend-multiply bg-cover bg-fixed"
			style={`background-image: url('${base}paper.png')`}
		>
		</div>

		<!-- Subtle vignette -->
		<div
			class="absolute inset-0 pointer-events-none z-0 shadow-2xl"
			style="box-shadow: inset 0 0 120px rgba(0, 0, 0, 0.08)"
		>
		</div>

		<div
			class="relative z-10 w-full max-w-3xl mx-auto flex flex-col items-center text-center"
		>
			<!-- Headline -->
			<h1
				class="font-headline text-[3.2rem] leading-[0.85] sm:text-7xl md:text-8xl lg:text-[6.5rem] w-full mb-4 sm:mb-6 md:mb-8 fade-in fade-delay-1"
			>
				<span
					class="block underline decoration-2 decoration-ink pb-2 sm:pb-3 mb-1"
					>What else is your</span
				>
				<span
					class="block underline decoration-2 decoration-ink pb-2 sm:pb-3"
					>ad agency selling?</span
				>
			</h1>

			<!-- Snake Oil Salesman Image — double border outside image -->
			<div
				class="mb-10 sm:mb-14 md:mb-16 w-full max-w-2xl mx-auto p-[5px] border border-ink fade-in fade-delay-2"
			>
				<div class="border-[3px] border-ink">
					<Image
						src={snakeoilImg}
						alt="A snake oil salesman holding a bottle of Snake Oil & Gas"
						class="w-full h-auto block opacity-95"
						widths={[500, 800, 1000]}
					/>
				</div>
			</div>

			<!-- Body Copy -->
			<div
				class="font-body text-base sm:text-lg md:text-xl leading-relaxed max-w-xl mx-auto mb-8 sm:mb-10 space-y-5 fade-in fade-delay-3"
			>
				<p>
					Some of the agencies working in healthcare also work for
					fossil fuel companies&nbsp;&mdash; whose pollution does
					wonders for cancer, asthma and everything in between.
				</p>
				<p>
					118 global health organisations have already committed to
					stop hiring agencies that work for the fossil fuel industry.
				</p>
			</div>

			<!-- CTA Section -->
			<div
				class="w-full max-w-xl mx-auto mb-10 sm:mb-14 fade-in fade-delay-4 border-2 border-ink font-body text-sm sm:text-base text-left"
			>
				<a
					href="https://fossilfreeadvertising.com/f-list/"
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-baseline justify-between gap-4 px-6 py-4 sm:px-8 sm:py-5 hover:bg-ink hover:text-paper transition-all duration-200 group"
				>
					<span
						><span class="mr-3 opacity-50">I.</span>Find out who
						else your agency works with</span
					>
					<span class="shrink-0 opacity-50 group-hover:opacity-100"
						>&rarr;</span
					>
				</a>
				<div class="border-t border-ink"></div>
				<a
					href="https://climateandhealthalliance.org/initiatives/cradle-to-grave/"
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-baseline justify-between gap-4 px-6 py-4 sm:px-8 sm:py-5 hover:bg-ink hover:text-paper transition-all duration-200 group"
				>
					<span
						><span class="mr-3 opacity-50">II.</span>Learn how
						fossil fuels are impacting our health</span
					>
					<span class="shrink-0 opacity-50 group-hover:opacity-100"
						>&rarr;</span
					>
				</a>
				<div class="border-t border-ink"></div>
				<a
					href="https://climateandhealthalliance.org/what-we-do/mobilise-the-movement/break-the-fossil-influence-campaign/"
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-baseline justify-between gap-4 px-6 py-4 sm:px-8 sm:py-5 hover:bg-ink hover:text-paper transition-all duration-200 group"
				>
					<span
						><span class="mr-3 opacity-50">III.</span>Commit to stop
						hiring agencies that work with fossil fuel companies
					</span>
					<span class="shrink-0 opacity-50 group-hover:opacity-100"
						>&rarr;</span
					>
				</a>
			</div>

			<!-- Snake Icon in Dark Circle -->
			<div class="fade-in fade-delay-5">
				<div
					class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-ink flex items-center justify-center p-4 sm:p-5 spin-slow"
				>
					<Image
						src={snakeImg}
						alt="Snake icon"
						class="w-full h-auto"
						width={80}
						height={80}
					/>
				</div>
			</div>
		</div>

		<!-- Footer -->
		<footer
			class="relative z-10 mt-8 sm:mt-12 text-center font-body text-sm text-ink fade-in fade-delay-5"
		>
			Made by <a
				href="https://seriouspeople.co"
				target="_blank"
				rel="noopener noreferrer"
				class="underline hover:opacity-70 transition-opacity duration-200"
				>Serious People</a
			>
		</footer>
	</main>
</Layout>

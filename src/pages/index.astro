---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import snakeoilImg from "../assets/snakeoil.png";
import snakeImg from "../assets/snake.png";

const base = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: import.meta.env.BASE_URL + "/";
---

<Layout>
	<main
		class="min-h-screen flex flex-col items-center justify-center px-4 py-10 sm:py-16 md:py-20 relative"
	>
		<!-- Paper texture overlay -->
		<div
			class="absolute inset-0 pointer-events-none z-0 opacity-30 mix-blend-multiply bg-repeat"
			style={`background-image: url('${base}paper.png')`}
		>
		</div>

		<div
			class="relative z-10 w-full max-w-3xl mx-auto flex flex-col items-center text-center"
		>
			<!-- Headline -->
			<h1
				class="font-headline text-[2.6rem] leading-[0.8] sm:text-7xl md:text-8xl lg:text-[6.5rem] w-full mb-10 sm:mb-14 md:mb-16"
			>
				<span
					class="block underline decoration-2 decoration-ink pb-2 sm:pb-3 mb-1"
					>What else is your</span
				>
				<span
					class="block underline decoration-2 decoration-ink pb-2 sm:pb-3"
					>ad agency selling?</span
				>
			</h1>

			<!-- Snake Oil Salesman Image — with double border, no padding -->
			<div
				class="mb-10 sm:mb-14 md:mb-16 w-full max-w-lg mx-auto border border-ink outline outline-[3px] outline-ink -outline-offset-[6px]"
			>
				<Image
					src={snakeoilImg}
					alt="A snake oil salesman holding a bottle of Snake Oil & Gas"
					class="w-full h-auto block"
					widths={[500, 800, 1000]}
				/>
			</div>

			<!-- Body Copy -->
			<div
				class="font-body text-base sm:text-lg md:text-xl leading-relaxed max-w-xl mx-auto mb-8 sm:mb-10 space-y-5"
			>
				<p>
					Some of the agencies working in healthcare also work for
					fossil fuel companies&nbsp;&mdash; whose pollution does
					wonders for cancer, asthma and everything in between.
				</p>
				<p>
					118 global health organisations have already signed the
					Fossil-Free Health Communications commitment.
				</p>
			</div>

			<!-- CTA Button -->
			<a
				href="https://climateandhealthalliance.org/what-we-do/mobilise-the-movement/break-the-fossil-influence-campaign/"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-block font-body text-sm sm:text-base border-2 border-ink px-8 py-3 sm:px-10 sm:py-4 hover:bg-ink hover:text-paper transition-colors duration-200 mb-10 sm:mb-14"
			>
				Take the commitment
			</a>

			<!-- Snake Icon in Dark Circle -->
			<div
				class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-ink flex items-center justify-center p-4 sm:p-5"
			>
				<Image
					src={snakeImg}
					alt="Snake icon"
					class="w-full h-auto"
					width={80}
					height={80}
				/>
			</div>
		</div>

		<!-- Footer -->
		<footer
			class="relative z-10 mt-8 sm:mt-12 text-center font-body text-sm text-ink"
		>
			Made by <a
				href="https://seriouspeople.co"
				target="_blank"
				rel="noopener noreferrer"
				class="underline hover:opacity-70 transition-opacity duration-200"
				>Serious People</a
			>
		</footer>
	</main>
</Layout>
